{
    "name": "@doenet/assignment-viewer",
    "private": false,
    "description": "View assignments from questions written in DoenetML",
    "version": "0.1.0-alpha-15",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/assignment-viewer#readme",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Doenet/assignment-viewer.git"
    },
    "files": [
        "/dist"
    ],
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*",
            "require": "./dist/*"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "test": "vitest",
        "test-cypress": "cypress open --component",
        "test-cypress-all": "cypress run --component -b 'chrome' --config video=false --headless",
        "lint": "eslint .",
        "preview": "vite preview",
        "prettier:format": "prettier --write .",
        "prettier:check": "prettier --check ."
    },
    "peerDependencies": {
        "@doenet/doenetml-iframe": "^0.7.20-dev.332",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "dependencies": {
        "nanoid": "^5.1.6",
        "object-hash": "^3.0.0",
        "react-icons": "^5.5.0",
        "seedrandom": "^3.0.5"
    },
    "devDependencies": {
        "@doenet/doenetml-iframe": "0.7.20-dev.332",
        "@eslint/js": "^9.39.1",
        "@types/object-hash": "^3.0.6",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/seedrandom": "^3.0.8",
        "@vitejs/plugin-react-swc": "^4.2.2",
        "cypress": "^15.18.0",
        "cypress-vite": "^1.10.2",
        "cypress-wait-until": "^3.0.2",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "prettier": "^3.7.4",
        "rollup-plugin-visualizer": "^6.0.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.49.0",
        "vite": "^7.2.7",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.15"
    },
    "prettier": {
        "tabWidth": 4
    }
}
